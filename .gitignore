# Build output
target/
*.class

# Gradle (M1 build)
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
# maven-shade-plugin generated
dependency-reduced-pom.xml

# M0 spike: upstream corpus clones (re-created via README reproduce steps) and extracted classpaths
milestones/m0-spike/corpus/
# M0 spike: generated Spike A artifacts (coverage/histogram/worksheets)
milestones/m0-spike/out/

# Index output. The default store now lives under ~/.cache/jcma (PRD §5.1); this is only a safety
# net for anyone who passes an explicit `jcma index <repo> .jcma`.
.jcma/

# Editor / OS
.idea/
*.iml
.vscode/
.DS_Store

# Eclipse / jdtls (Buildship import — IDE metadata + its parallel bin/ compile output)
.project
.classpath
.settings/
bin/

# Stray dependency sources extracted by the IDE's "go to definition" (not project code)
com/

# Note: .mcp.json is tracked — it's portable (${JCMA_BINARY:-jcma}) and wires local
# dogfooding of jcma in this repo. The Claude Code plugin ships its own declaration at
# plugin/.mcp.json. Machine-specific paths live in the (ignored) .claude/settings.local.json.
